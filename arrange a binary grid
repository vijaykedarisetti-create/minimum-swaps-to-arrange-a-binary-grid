from typing import List

class Solution:
    def minSwaps(self, grid: List[List[int]]) -> int:
        n = len(grid)

        # trailing_zeros[i] = number of zeros at the end of row i
        trailing_zeros = []
        for row in grid:
            cnt = 0
            for v in reversed(row):
                if v == 0:
                    cnt += 1
                else:
                    break
            trailing_zeros.append(cnt)

        swaps = 0

        # For each row i, we need at least (n - 1 - i) trailing zeros
        for i in range(n):
            need = n - 1 - i
            j = i
            # Find first row j >= i that satisfies the requirement
            while j < n and trailing_zeros[j] < need:
                j += 1
            if j == n:
                return -1  # impossible

            # Bring row j up to position i by adjacent swaps
            while j > i:
                trailing_zeros[j], trailing_zeros[j - 1] = trailing_zeros[j - 1], trailing_zeros[j]
                swaps += 1
                j -= 1

        return swaps
